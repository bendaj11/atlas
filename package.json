{
  "name": "atlas-platform",
  "version": "0.3.21",
  "private": true,
  "description": "TypeScript-first app platform with focused SDK, runtime, static registry, generators and test tooling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git"
  },
  "homepage": "https://github.com/bendaj11/atlas#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "build": "turbo run build --filter='@atlas/*'",
    "build:affected": "turbo run build --affected --filter='@atlas/*'",
    "build:examples": "NG_BUILD_MAX_WORKERS=1 turbo run build --concurrency=1 --filter='@atlas-example/*' --filter='@atlas-app/*'",
    "ci:affected": "pnpm run typecheck:affected && pnpm run check:unused && pnpm run test:affected",
    "ci:full": "pnpm run typecheck && pnpm run check:unused && pnpm run test",
    "pack:verify": "node scripts/verify-packages.js",
    "release": "node scripts/prepare-release.js",
    "release:bundle": "pnpm run pack:verify && node scripts/create-release-bundle.js",
    "release:version": "node scripts/version-packages.js",
    "test:generated": "pnpm run pack:verify && node scripts/verify-generated-projects.js --package-manager=yarn && node scripts/verify-generated-projects.js --package-manager=pnpm",
    "test": "pnpm run test:packages && NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.json --testPathPattern='scripts/'",
    "test:affected": "turbo run test --affected --filter='@atlas/*'",
    "test:fixtures": "pnpm --filter @atlas-app/catalog-react run build",
    "test:packages": "turbo run test --filter='@atlas/*'",
    "test:e2e": "node tests/e2e/prepare.js && playwright test",
    "test:container": "pnpm run pack:verify && node scripts/verify-bootstrap-container.js",
    "test:e2e:prepare": "node tests/e2e/prepare.js",
    "typecheck": "turbo run typecheck --filter='@atlas/*' && pnpm run typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "typecheck:affected": "turbo run typecheck --affected --filter='@atlas/*'",
    "check:unused": "tsc -p packages/cli/tsconfig.json --noEmit --composite false --noUnusedLocals --noUnusedParameters",
    "atlas": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/jest": "29.5.14",
    "@types/node": "^22",
    "jest": "29.7.0",
    "prettier": "3.9.5",
    "ts-jest": "29.2.5",
    "turbo": "^2.6.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
