{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.driver.ts",
    "src/**/*.driver.tsx",
    "src/**/*.specs.ts",
    "src/**/*.specs.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
