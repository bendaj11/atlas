{
  "extensionsToTreatAsEsm": [".ts"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "modulePathIgnorePatterns": ["<rootDir>/dist/"],
  "rootDir": ".",
  "testPathIgnorePatterns": ["<rootDir>/tests/e2e/"],
  "testEnvironment": "node",
  "testMatch": ["**/*.specs.ts"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "diagnostics": true,
        "tsconfig": "<rootDir>/tsconfig.tests.json",
        "useESM": true
      }
    ]
  }
}
