{
  "name": "@atlas/host-server",
  "version": "0.2.76",
  "type": "module",
  "description": "Portable Atlas bootstrap server for versioned host clients.",
  "license": "MIT",
  "keywords": ["atlas", "host", "server", "container"],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/host-server"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/host-server#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "atlas-host-server": "./dist/cli.js"
  },
  "files": ["dist/**/*.js", "dist/**/*.d.ts"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -b",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ../../jest.config.json --testPathPattern='packages/host-server/tests/'",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  },
  "dependencies": {
    "@atlas/schema": "0.2.76",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
