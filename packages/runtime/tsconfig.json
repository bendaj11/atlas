{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@atlas/contracts": ["../contracts/src/index.ts"],
      "@atlas/sdk": ["../sdk/src/index.ts"],
      "@atlas/sdk/*": ["../sdk/src/*.ts"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "references": [{ "path": "../contracts" }, { "path": "../sdk" }],
  "include": ["src/**/*.ts"]
}
