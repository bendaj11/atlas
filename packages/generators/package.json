{
  "name": "@atlas/generators",
  "version": "0.2.39",
  "type": "module",
  "description": "Project generators used internally by the Atlas CLI.",
  "license": "MIT",
  "keywords": [
    "app",
    "generator",
    "native-federation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/generators"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/generators#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node -e \"\"",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  },
  "dependencies": {
    "@atlas/schema": "0.2.39"
  }
}
