{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@atlas/bootstrap": ["../bootstrap/src/index.ts"],
      "@atlas/schema": ["../schema/src/index.ts"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true
  },
  "references": [{ "path": "../bootstrap" }, { "path": "../schema" }],
  "include": ["src/**/*.ts"]
}
