{
  "name": "@atlas/cli",
  "version": "0.3.9",
  "type": "module",
  "description": "Interactive Atlas project generation, development, and static publication tooling.",
  "license": "MIT",
  "keywords": [
    "app",
    "cli",
    "native-federation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/cli#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "atlas": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node dist/index.js compile-config catalog-react && yarn workspace @atlas-app/catalog-react build && NODE_OPTIONS=--experimental-vm-modules jest --config ../../jest.config.json --testPathPattern='packages/cli/tests/'",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  },
  "dependencies": {
    "@atlas/bootstrap": "0.3.9",
    "@atlas/schema": "0.3.9",
    "@atlas/generators": "0.3.9",
    "@atlas/runtime": "0.3.9",
    "@inquirer/select": "^4.4.2",
    "typescript": "~5.9.0"
  }
}
