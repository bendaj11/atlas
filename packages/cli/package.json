{
  "name": "@atlas/cli",
  "version": "0.2.52",
  "type": "module",
  "description": "Interactive Atlas project generation, development, and static publication tooling.",
  "license": "MIT",
  "keywords": [
    "app",
    "cli",
    "native-federation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/cli#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "atlas": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "yarn workspace @atlas-mf/catalog-react build && node --test tests/*.test.mjs",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  },
  "dependencies": {
    "@atlas/schema": "0.2.52",
    "@atlas/generators": "0.2.52",
    "@atlas/runtime": "0.2.52",
    "@inquirer/select": "^4.4.2",
    "typescript": "~5.9.0"
  }
}
