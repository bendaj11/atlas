{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@atlas/schema": ["../schema/src/index.ts"],
      "@atlas/generators": ["../generators/src/index.ts"],
      "@atlas/host-server": ["../host-server/src/index.ts"],
      "@atlas/runtime": ["../runtime/src/index.ts"],
      "@atlas/sdk": ["../sdk/src/index.ts"],
      "@atlas/sdk/*": ["../sdk/src/*.ts"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "../schema" },
    { "path": "../generators" },
    { "path": "../host-server" },
    { "path": "../runtime" },
    { "path": "../sdk" }
  ],
  "include": ["src/**/*.ts"]
}
