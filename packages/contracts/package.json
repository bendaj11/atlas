{
  "name": "@atlas/contracts",
  "version": "0.2.10",
  "type": "module",
  "description": "Stable Atlas manifests, static indexes, catalogs, and configuration contracts.",
  "license": "MIT",
  "keywords": [
    "microfrontend",
    "typescript",
    "contracts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/contracts#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  }
}
