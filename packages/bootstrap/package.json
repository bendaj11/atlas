{
  "name": "@atlas/bootstrap",
  "version": "0.3.6",
  "type": "module",
  "description": "Static Atlas browser bootstrap assets and Nginx configuration.",
  "license": "MIT",
  "keywords": [
    "atlas",
    "host",
    "static",
    "nginx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bendaj11/atlas.git",
    "directory": "packages/bootstrap"
  },
  "homepage": "https://github.com/bendaj11/atlas/tree/main/packages/bootstrap#readme",
  "bugs": "https://github.com/bendaj11/atlas/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ../../jest.config.json --testPathPattern='packages/bootstrap/tests/'",
    "typecheck": "tsc -b --pretty false",
    "publish-lib": "npm publish --registry http://localhost:4873"
  },
  "dependencies": {
    "@atlas/schema": "0.3.6"
  }
}
